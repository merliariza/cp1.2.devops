pipeline {

    agent any

    environment {
        PYTHON   = 'C:\\Users\\merli\\AppData\\Local\\Programs\\Python\\Python314\\python.exe'
        JMETER   = 'C:\\Users\\merli\\Downloads\\apache-jmeter-5.6.3\\apache-jmeter-5.6.3\\bin\\jmeter.bat'
        API_PORT = '9090'
    }

    options {
        disableConcurrentBuilds()
    }

    stages {

        stage('Get Code') {
            steps {
                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat '"%PYTHON%" -m pip install --upgrade pip'
                bat '"%PYTHON%" -m pip install flask pytest coverage flake8 bandit requests'
            }
        }

        stage('Unit Tests') {
            steps {
                bat '"%PYTHON%" -m coverage run --branch --source=app -m pytest test/unit --junitxml=result-unit.xml'
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'result-unit.xml'
                }
            }
        }

        stage('Coverage') {
            steps {
                bat '"%PYTHON%" -m coverage xml -o coverage.xml'
                bat '"%PYTHON%" -m coverage report'
            }
            post {
                always {
                    archiveArtifacts artifacts: 'coverage.xml', allowEmptyArchive: true
                }
            }
        }

        stage('Static Analysis (flake8)') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    bat '"%PYTHON%" -m flake8 . --tee --output-file=flake8-report.txt'
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'flake8-report.txt', allowEmptyArchive: true
                }
            }
        }

        stage('Security (bandit)') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    bat '"%PYTHON%" -m bandit -r app -f json -o bandit-report.json'
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'bandit-report.json', allowEmptyArchive: true
                }
            }
        }

        stage('Start API') {
            steps {
                bat 'start /B "" "%PYTHON%" -m app.api > api.log 2>&1'
                bat 'powershell -Command "Start-Sleep -Seconds 20"'
                bat 'netstat -ano | findstr :%API_PORT%'
            }
        }

        stage('REST Tests') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                    bat '"%PYTHON%" -m pytest test/rest --junitxml=result-rest.xml'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'result-rest.xml'
                }
            }
        }

        stage('Performance (JMeter)') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                    bat '"%JMETER%" -n -t test\\jmeter\\performance.jmx -l performance-results.jtl'
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'performance-results.jtl', allowEmptyArchive: true
                }
            }
        }

        stage('Stop API') {
            steps {
                bat 'taskkill /F /IM python.exe /T || echo Sin proceso Python activo'
            }
        }
    }

    post {
        always {
            bat 'taskkill /F /IM python.exe /T || echo Sin proceso Python activo'
            archiveArtifacts artifacts: '*.xml,*.txt,*.json,*.jtl,*.log', fingerprint: true, allowEmptyArchive: true
        }
        cleanup {
            bat 'exit 0'
            cleanWs()
        }
    }
}