pipeline {

    agent any

    environment {
        PYTHON = 'python'
    }

    options {
        disableConcurrentBuilds()
    }

    stages {

        stage('Debug Python') {
            steps {
                bat 'python --version'
            }
        }

        stage('Get Code') {
            steps {
                echo 'Obteniendo codigo fuente...'

                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'
            }
        }

        stage('Unit') {
            steps {

                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'

                bat '''
                    python -m coverage run --branch -m pytest test/unit --junitxml=result-unit.xml
                '''
            }

            post {
                always {
                    junit 'result-unit.xml'
                }
            }
        }

        stage('Coverage') {
            steps {

                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'

                bat '''
                    python -m coverage xml -o coverage.xml
                    python -m coverage report
                '''

                recordCoverage(
                    tools: [[parser: 'COBERTURA', pattern: 'coverage.xml']],
                    sourceCodeRetention: 'EVERY_BUILD',
                    enabledForFailure: true,
                    failNoReports: true,
                    globalThresholds: [
                        [thresholdTarget: 'LINE', unhealthyThreshold: 85.0, unstableThreshold: 95.0],
                        [thresholdTarget: 'BRANCH', unhealthyThreshold: 80.0, unstableThreshold: 90.0]
                    ]
                )
            }
        }

        stage('Static') {
            steps {

                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'

                catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                    bat '''
                        python -m flake8 . --tee --output-file=flake8-report.txt
                    '''
                }

                recordIssues(
                    enabledForFailure: true,
                    tools: [flake8(pattern: 'flake8-report.txt')],
                    qualityGates: [
                        [threshold: 8, type: 'TOTAL', unstable: true],
                        [threshold: 10, type: 'TOTAL', failure: true]
                    ]
                )
            }
        }

        stage('Security Test') {
            steps {

                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'

                catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                    bat '''
                        python -m bandit -r app -f json -o bandit-report.json
                    '''
                }

                recordIssues(
                    enabledForFailure: true,
                    tools: [bandit(pattern: 'bandit-report.json')],
                    qualityGates: [
                        [threshold: 2, type: 'TOTAL', unstable: true],
                        [threshold: 4, type: 'TOTAL', failure: true]
                    ]
                )
            }
        }

        stage('REST') {
            steps {

                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'

                bat '''
                    start /B python -m app.api
                '''

                bat '''
                    timeout /t 15 /nobreak
                '''

                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    bat '''
                        python -m pytest test/rest --junitxml=result-rest.xml
                    '''
                }

                bat '''
                    taskkill /F /IM python.exe /T
                '''
            }

            post {
                always {
                    junit 'result-rest.xml'
                }
            }
        }

        stage('Performance') {
            steps {

                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'

                bat '''
                    start /B python -m app.api
                '''

                bat '''
                    timeout /t 15 /nobreak
                '''

                bat '''
                    C:\\Users\\merli\\Downloads\\apache-jmeter-5.6.3\\apache-jmeter-5.6.3\\bin\\jmeter.bat -n -t test\\jmeter\\performance.jmx -l performance-results.jtl
                '''

                bat '''
                    taskkill /F /IM python.exe /T
                '''
            }

            post {
                always {

                    perfReport(
                        sourceDataFiles: 'performance-results.jtl',
                        errorFailedThreshold: 0,
                        errorUnstableThreshold: 0
                    )
                }
            }
        }
    }

    post {

        always {
            archiveArtifacts artifacts: '*.xml,*.txt,*.json,*.jtl', fingerprint: true
        }

        cleanup {
            cleanWs()
        }
    }
}