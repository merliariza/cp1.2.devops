pipeline {

    agent any

    environment {
        PYTHON = 'python'
        JMETER = 'C:\\Users\\merli\\Downloads\\apache-jmeter-5.6.3\\apache-jmeter-5.6.3\\bin\\jmeter.bat'
    }

    options {
        disableConcurrentBuilds()
    }

    stages {

        stage('Get Code') {
            steps {
                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'
            }
        }

        stage('Unit') {
            steps {
                bat '"%PYTHON%" -m pytest test/unit --junitxml=result-unit.xml'
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'result-unit.xml'
                }
            }
        }

        stage('Coverage') {
            steps {
                bat '"%PYTHON%" -m coverage run --branch --source=app -m pytest test/unit'
                bat '"%PYTHON%" -m coverage xml -o coverage.xml'
                bat '"%PYTHON%" -m coverage report'
            }
            post {
                always {
                    archiveArtifacts artifacts: 'coverage.xml', allowEmptyArchive: true
                }
            }
        }

        stage('Static') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                    bat '"%PYTHON%" -m flake8 . --output-file=flake8-report.txt'
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'flake8-report.txt', allowEmptyArchive: true
                }
            }
        }

        stage('Security Test') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                    bat '"%PYTHON%" -m bandit -r app -f json -o bandit-report.json'
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'bandit-report.json', allowEmptyArchive: true
                }
            }
        }

        stage('REST') {
            steps {
                bat 'start /B "%PYTHON%" -m app.api'
                bat 'timeout /t 10 /nobreak'

                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    bat '"%PYTHON%" -m pytest test/rest --junitxml=result-rest.xml'
                }

                bat 'taskkill /F /IM python.exe /T'
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'result-rest.xml'
                }
            }
        }

        stage('Performance') {
            steps {
                bat 'start /B "%PYTHON%" -m app.api'
                bat 'timeout /t 10 /nobreak'

                bat '"%JMETER%" -n -t test\\jmeter\\performance.jmx -l performance-results.jtl'

                bat 'taskkill /F /IM python.exe /T'
            }
            post {
                always {
                    archiveArtifacts artifacts: 'performance-results.jtl', allowEmptyArchive: true
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: '*.xml,*.txt,*.json,*.jtl', allowEmptyArchive: true
        }
        cleanup {
            cleanWs()
        }
    }
}