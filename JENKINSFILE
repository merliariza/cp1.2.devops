pipeline {
    agent any

    stages {

        stage('Get Code') {
            steps {
                echo 'Obteniendo codigo...'
            }
        }

        stage('Build') {
            steps {
                bat 'python --version'
                bat 'dir'
            }
        }

        stage('Unit Tests') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {

                    bat '''
                        python -m coverage run -m pytest test/unit --junitxml=result-unit.xml
                        python -m coverage xml
                    '''
                }
            }
        }

        stage('Flake8') {
            steps {
                bat '''
                    python -m flake8 . --output-file=flake8-report.txt
                '''
            }
        }

        stage('Bandit') {
            steps {
                bat '''
                    python -m bandit -r app -f txt -o bandit-report.txt
                '''
            }
        }

        stage('REST Tests') {
            steps {

                bat '''
                    start /B python app/api.py
                '''

                bat '''
                    start /B java -jar test\\wiremock\\wiremock-standalone-3.13.2.jar --port 9090 --root-dir test\\wiremock
                '''

                bat '''
                    timeout /t 10
                '''

                bat '''
                    python -m pytest test/rest --junitxml=result-rest.xml
                '''
            }
        }

        stage('Results') {
            steps {
                junit 'result-*.xml'
            }
        }
    }
}